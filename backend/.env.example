# ===========================================
# Restaurant Waiter Agent — Environment Config
# ===========================================
# Copy this file to .env and fill in values.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL (used inside Docker) ---
POSTGRES_DB=restaurant_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Set to "true" to use SQLite instead of PostgreSQL (local dev without Docker)
USE_SQLITE=false

# --- Anthropic LLM ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI Embeddings (optional, for RAG) ---
# If not set, falls back to zero vectors (no semantic search)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Payment Gateways (Ethiopian) ---
# Chapa
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=

# Telebirr
TELEBIRR_APP_ID=
TELEBIRR_APP_SECRET=

# CBE Birr
CBE_BIRR_API_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
