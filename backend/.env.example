# ===========================================
# Restaurant Waiter Agent — Environment Config
# ===========================================
# Copy this file to .env and fill in values.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL (used inside Docker) ---
POSTGRES_DB=restaurant_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Set to "true" to use SQLite instead of PostgreSQL (local dev without Docker)
USE_SQLITE=false

# --- LLM Configuration (Hugging Face Inference API) ---
# Get your free token at https://huggingface.co/settings/tokens
LLM_API_KEY=hf_your_token_here
LLM_BASE_URL=https://api-inference.huggingface.co/v1
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- OpenAI Embeddings (optional, for RAG) ---
# If not set, falls back to zero vectors (no semantic search)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Payment Gateways (Ethiopian) ---
# Chapa — get keys at https://app.chapa.co/developers
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=

# Frontend URL for payment callbacks
FRONTEND_BASE_URL=http://localhost:5173

# --- CORS ---
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
