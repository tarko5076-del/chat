# ===========================================
# Restaurant Waiter Agent — Environment Config
# ===========================================
# Copy this file to .env and fill in values.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL (used inside Docker) ---
POSTGRES_DB=restaurant_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Set to "true" to use SQLite instead of PostgreSQL (local dev without Docker)
USE_SQLITE=false

# --- LLM Configuration (Hugging Face) ---
# Get your free token at https://huggingface.co/settings/tokens
# The system uses Hugging Face Inference API (OpenAI-compatible) out of the box.
# Recommended model: meta-llama/Llama-3.1-8B-Instruct (free tier available)
#
# You can also use OpenRouter, OpenAI, or any OpenAI-compatible provider:
#   LLM_API_KEY=sk-or-v1-your-key
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=openai/gpt-4o-mini
#
# Leave empty to use rule-based LocalPlanner (no AI conversation, but all order/reservation flows work)
HF_TOKEN=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
# HF_BASE_URL defaults to https://api-inference.huggingface.co/v1

# Override defaults: use LLM_* vars to use a different OpenAI-compatible provider
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# --- LLM Fallback (used when primary is down/rate-limited) ---
# Set to a different provider/model for automatic failover
# LLM_FALLBACK_API_KEY=
# LLM_FALLBACK_BASE_URL=
# LLM_FALLBACK_MODEL=

# --- Embeddings (for RAG / semantic search) ---
# OpenAI embeddings: set OPENAI_API_KEY for text-embedding-3-small (1536 dims)
# Hugging Face embeddings: set HF_TOKEN + HF_EMBEDDING_MODEL (e.g. sentence-transformers/all-MiniLM-L6-v2)
# If neither is set, falls back to zero vectors (no semantic search, exact-match only)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Payment Gateways (Ethiopian) ---
# Chapa — get keys at https://app.chapa.co/developers
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
# Webhook "Secret Hash" set in the Chapa dashboard — used to verify webhook signatures.
CHAPA_WEBHOOK_SECRET=

# Frontend URL for payment callbacks
FRONTEND_BASE_URL=http://localhost:5173

# --- Email (for order/payment confirmations) ---
# Default: console backend (prints to terminal in dev)
# For production: use smtp, sendgrid, ses, etc.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@restaurant-agent.com

# --- CORS ---
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# --- Docker Entrypoint ---
# Set to "true" to clear and re-seed menu items & knowledge base on startup
FORCE_REFRESH=false
